# GitHub Actions → Repository secrets 체크리스트
# Settings → Secrets and variables → Actions 에 아래 이름으로 등록하세요.
# 이 파일은 예시일 뿐이며, 실제 비밀값은 커밋하지 마세요.

# --- AWS / ECR / EKS ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
ECR_FRONTEND_URI=105588835975.dkr.ecr.ap-northeast-2.amazonaws.com/rookies5-macta/frontend
EKS_CLUSTER_NAME=rookies5-macta-eks

# --- Argo CD (infra repo push용 PAT) ---
ARGOCD_GIT_TOKEN=ghp_...

# --- Frontend build-time ---
VITE_API_BASE_URL=https://macta.store/api
