# GitHub Actions → Repository secrets 체크리스트
# Settings → Secrets and variables → Actions 에 아래 이름으로 등록하세요.
# 이 파일은 예시일 뿐이며, 실제 비밀값은 커밋하지 마세요.

# --- AWS / ECR / EKS ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
ECR_BACKEND_URI=105588835975.dkr.ecr.ap-northeast-2.amazonaws.com/rookies5-macta/backend
EKS_CLUSTER_NAME=rookies5-macta-eks

# --- Argo CD (infra repo push용 PAT) ---
ARGOCD_GIT_TOKEN=ghp_...

# --- App runtime (SSM → ExternalSecret → Pod env) ---
DB_URL=jdbc:mariadb://xxxx.ap-northeast-2.rds.amazonaws.com:3306/mactadb?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=admin
DB_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-string

# Redis (in-cluster). HOST는 Service 이름이어야 함.
REDIS_HOST=rookies5-macta-redis-service
REDIS_PORT=6379
REDIS_PASSWORD=change-me

S3_BUCKET_NAME=macta-bucket
AWS_S3_BASE_DIRECTORY=auction-images
AWS_S3_PRESIGNED_URL_EXPIRATION_MINUTES=120
AWS_S3_MAX_UPLOAD_SIZE=10485760
